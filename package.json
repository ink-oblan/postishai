{
  "name": "postishai",
  "version": "0.0.8",
  "private": true,
  "scripts": {
    "dev": "docker compose up --build",
    "start": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build -d",
    "stop": "docker compose down",
    "logs": "docker compose logs -f app worker",
    "backup:db": "tsx scripts/backup-postgres-to-s3.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "app:dev": "next dev 2>&1 | tee dev.log",
    "app:dev:docker": "npx prisma generate && npm run app:dev",
    "app:build": "next build",
    "app:start": "node .next/standalone/server.js",
    "app:start:logged": "node .next/standalone/server.js 2>&1 | tee dev.log",
    "worker:dev": "tsx watch src/worker.ts 2>&1 | tee worker.log",
    "worker:start": "tsx src/worker.ts 2>&1 | tee worker.log"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@base-ui/react": "^1.3.0",
    "@google/genai": "^1.46.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.5.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "framer-motion": "^12.38.0",
    "handlebars": "^4.7.8",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mts,mjs,cjs,json,css}": "biome check --fix --no-errors-on-unmatched --error-on-warnings"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.5"
  }
}
