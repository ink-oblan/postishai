generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Avatar {
  id             String            @id @default(cuid())
  name           String
  prompt         String?
  imageModel     String?
  imagePath      String
  gender         String?           // "man" | "woman" | "neutral"
  age            Int?
  ethnicity      String?
  origin         String?
  occupation     String?
  status         String            @default("COMPLETED")  // GENERATING | COMPLETED | FAILED
  errorMessage   String?
  voiceId        String            @default("")
  heygenAssetId  String?
  heygenAssetUrl String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  archivedAt     DateTime?
  posts          Post[]
  variations     AvatarVariation[]
}

model AvatarVariation {
  id             String   @id @default(cuid())
  avatarId       String
  avatar         Avatar   @relation(fields: [avatarId], references: [id])
  label          String
  clothes        String?
  background     String?
  pose           String?
  prompt         String?
  imageModel     String?
  imagePath      String   @default("")
  status         String   @default("PENDING")  // PENDING | GENERATING | COMPLETED | FAILED
  errorMessage   String?
  heygenAssetId  String?
  heygenAssetUrl String?
  posts          Post[]
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Job {
  id        String   @id @default(cuid())
  type      String   // "avatar.generate"
  payload   String   // JSON
  status    String   @default("PENDING")  // PENDING | PROCESSING | COMPLETED | FAILED
  attempts  Int      @default(0)
  maxAttempts Int    @default(3)
  dedupeKey String?
  runAfter  DateTime @default(now())
  lockedAt  DateTime?
  lockedBy  String?
  error     String?
  finishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id                  String           @id @default(cuid())
  title               String
  platform            Platform
  script              String
  avatarId            String
  avatar              Avatar           @relation(fields: [avatarId], references: [id])
  avatarVariationId   String?
  avatarVariation     AvatarVariation? @relation(fields: [avatarVariationId], references: [id])
  llmModelId     String     @default("gemini-2.0-flash")
  status         PostStatus @default(DRAFT)
  generationStartedAt DateTime?
  heygenVideoId  String?
  videoPath      String?
  heygenVideoUrl String?
  metadata       String?
  metadataStatus String     @default("IDLE")
  metadataErrorMessage String?
  metadataUpdatedAt DateTime?
  errorMessage   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  archivedAt     DateTime?
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE_SHORTS
}

enum PostStatus {
  DRAFT
  GENERATING
  COMPLETED
  FAILED
}
