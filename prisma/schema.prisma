generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  passwordHash       String?
  avatarUrl          String?
  role               Role      @default(USER)
  approvedAt         DateTime?
  approvalToken      String?   @unique
  approvalDetails    String?
  approvalNotifiedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  accounts           Account[]
  sessions           Session[]
  avatars            Avatar[]
  posts              Post[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Avatar {
  id                  String  @id @default(cuid())
  name                String
  prompt              String?
  imageModel          String?
  imagePath           String
  gender              String? // "man" | "woman" | "neutral"
  age                 Int?
  origin              String?
  occupation          String?
  analysisDescription String?

  status         String            @default("COMPLETED")
  source         String // UPLOADED | GENERATED
  errorMessage   String?
  voiceId        String            @default("")
  heygenAssetId  String?
  heygenAssetUrl String?
  userId         String?
  user           User?             @relation(fields: [userId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  archivedAt     DateTime?
  posts          Post[]
  variations     AvatarVariation[]
}

model HeyGenVoice {
  id           String   @id @default(cuid())
  voiceId      String   @unique
  name         String
  language     String
  gender       String
  previewAudio String?
  raw          Json?
  active       Boolean  @default(true)
  lastSeenAt   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([language, gender, name])
}

model AvatarVariation {
  id             String    @id @default(cuid())
  avatarId       String
  avatar         Avatar    @relation(fields: [avatarId], references: [id])
  label          String    @db.VarChar(60)
  clothes        String?
  background     String?
  pose           String?
  prompt         String?
  imageModel     String?
  imagePath      String    @default("")
  status         String    @default("PENDING")
  errorMessage   String?
  heygenAssetId  String?
  heygenAssetUrl String?
  posts          Post[]
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Job {
  id          String    @id @default(cuid())
  type        String // "avatar.generate"
  payload     String // JSON
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  dedupeKey   String?
  runAfter    DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  error       String?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PlatformConfig {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id                   String           @id @default(cuid())
  type                 PostType         @default(AVATAR_VIDEO)
  title                String
  platform             Platform
  script               String?
  details              String?
  avatarId             String?
  avatar               Avatar?          @relation(fields: [avatarId], references: [id])
  avatarVariationId    String?
  avatarVariation      AvatarVariation? @relation(fields: [avatarVariationId], references: [id])
  caption              String?
  media                PostMedia[]
  userId               String?
  user                 User?            @relation(fields: [userId], references: [id])
  llmModelId           String           @default("gemini-2.0-flash")
  status               String           @default("DRAFT")
  generationStartedAt  DateTime?
  heygenVideoId        String?
  videoPath            String?
  heygenVideoUrl       String?
  metadata             String?
  metadataStatus       String           @default("IDLE")
  metadataErrorMessage String?
  metadataUpdatedAt    DateTime?
  errorMessage         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  archivedAt           DateTime?
}

model PostMedia {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  type      String // "IMAGE" | "VIDEO"
  path      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE_SHORTS
}

enum PostType {
  AVATAR_VIDEO
  CAPTION
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
