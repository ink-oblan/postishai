# ── Required ──────────────────────────────────────────────────
# Fill these in before starting the app.

HEYGEN_API_KEY=""
GOOGLE_API_KEY=""

# ── Optional ─────────────────────────────────────────────────
# Defaults work for local development; override as needed.

POSTGRES_PASSWORD="postishai"
STORAGE_PATH="./storage"
STORAGE_ARCHIVE_PREFIX="archive"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mock mode for testing SSE without calling external APIs
# Enables fast placeholder generation for avatars (10s), videos (15s), and captions (5s)
# Set to "true" for testing, "false" for production with real AI models
NEXT_PUBLIC_MOCK_MODE="false"

# S3 media storage, if turned on, provide credentials in section below.
# Set USE_S3_AS_STORAGE to "true" before first startup to store media in S3.
# Once initialized, storage mode is pinned in PlatformConfig.storage.mode.
# At this moment, switching/migrating storage not implemented, it should be done manually.
USE_S3_AS_STORAGE="false"
S3_PREFIX="storage"

# Shared AWS S3 configuration for media storage and database backups
S3_BUCKET=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Auth
SESSION_SECRET="postishai-local-dev-secret-change-before-production"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Signup approval via Telegram (leave empty to disable)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_APPROVAL_CHAT_ID=""

# Social network integrations
TIKTOK_API_CLIENT_KEY=""
TIKTOK_API_CLIENT_SECRET=""

# Database backup. Optional, if scripts/backup-postgres.sh is used.
# If used, provide S3 credentials in section above.
POSTGRES_BACKUP_S3_PREFIX="backups"
POSTGRES_BACKUP_DOCKER_SERVICE=""
POSTGRES_BACKUP_COMPOSE_FILE=""
